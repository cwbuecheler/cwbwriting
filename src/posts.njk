<h3>Post Archive</h3>

{% set postslist = collections.posts | sortByDate() %}

<ul class="postlist">
  {% for post in postslist %}
  <li class="postlist-item">
    <h4 datetime="{{ post.data.day }}">{{ post.data.day | readableDate }}</h4>
    <a href="{{ post.url | url }}">{% if post.data.headline %}{{ post.data.headline }}{% else %}<code>{{ post.url }}</code>{% endif %}</a>
  </li>
  {% endfor %}
</ul>

